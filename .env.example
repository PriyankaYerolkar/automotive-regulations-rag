# .env.example — copy to .env and fill in real values. .env is gitignored.

# LLM provider (choose one)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Embeddings (if using paid)
# OPENAI_API_KEY is reused for embeddings

# Vector store (when using Qdrant Cloud — Phase 4+)
QDRANT_URL=
QDRANT_API_KEY=

# Application
LOG_LEVEL=INFO