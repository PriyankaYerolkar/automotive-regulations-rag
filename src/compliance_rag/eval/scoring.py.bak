import json
import logging
import re

from ..generate import Chunk, DISCLAIMER, _build_context, render_citation
from ..llm.base import LLMClient

logger = logging.getLogger(__name__)

REFUSAL = "i could not find this in the retrieved documents"
_TAG_RE = re.compile(r"\[Source:[^\]]+\")
_JUDGE_SYSTEM = (
    "You are a strict grader. Given CONTEXT and an ANSWER, decide whether every "
    "substantive factual claim in the ANSWER is supported by the CONTEXT. The CONTEXT "
    "includes a source citation tag (regulation, section, page, effective date) for "
    "each passage; treat a section number, page number, effective date, or "
    "[Source: ...] tag in the ANSWER as supported when it appears in the CONTEXT. "
    'Respond with ONLY JSON: {"supported": true|false, "unsupported": ["..."]}. '
    "No prose, no fences."
)


def emitted_tags(answer: str) -> list[str]:
    """Every [Source: ...] tag the model wrote, in order."""
    return _TAG_RE.findall(answer)


def _context_tags(chunks: list[Chunk]) -> set[str]:
    """Valid citation tags for the chunks the model was given."""
    return {render_citation(c) for c in chunks}


def citation_score(answer: str, chunks: list[Chunk]) -> float:
    """Answerable item: 1.0 if it cites and every tag exists in context, else 0.0.

    Because citations are rendered in code and copied verbatim, a tag that is not
    in context is a fabrication — the dominant citation failure mode.
    """
    tags = emitted_tags(answer)
    if not tags:
        return 0.0
    return 1.0 if all(t in _context_tags(chunks) for t in tags) else 0.0


def bait_hallucinated(answer: str, chunks: list[Chunk]) -> bool:
    """True if a bait item was mishandled: no refusal, or a fabricated citation."""
    refused = REFUSAL in answer.lower()
    fabricated = any(t not in _context_tags(chunks) for t in emitted_tags(answer))
    return fabricated or not refused


def _extract_json(raw: str) -> dict | None:
    """Parse the judge's JSON object, tolerating code fences and trailing prose."""
    raw = raw.strip().removeprefix("```json").removeprefix("```").removesuffix("```").strip()
    candidates = [raw]
    # greedy: first '{' to last '}' — survives nested braces, unlike a lazy match
    m = re.search(r"\{.*\}", raw, re.DOTALL)
    if m:
        candidates.append(m.group())
    for c in candidates:
        try:
            return json.loads(c)
        except json.JSONDecodeError:
            continue
    return None


def faithfulness(answer: str, chunks: list[Chunk], judge: LLMClient) -> float:
    """LLM-judged: 1.0 if all substantive claims are supported by context, else 0.0."""
    claims = answer.replace(DISCLAIMER, "").strip()
    if not claims:
        # Nothing substantive to support (e.g. a bare refusal) — vacuously faithful.
        return 1.0

    # Reuse generation's context builder so the judge sees EXACTLY what the model
    # saw — parent heading + chunk text + citation tag. Feeding the judge a thinner
    # context (text only) was the original ~0.5 faithfulness bug.
    user = f"CONTEXT:\n{_build_context(chunks)}\n\nANSWER:\n{claims}"
    for attempt in range(2):  # one retry guards against a transient unparseable reply
        raw = judge.generate(_JUDGE_SYSTEM, user, temperature=0.0, max_tokens=512)
        verdict = _extract_json(raw)
        if verdict is not None:
            return 1.0 if verdict.get("supported") else 0.0
        logger.warning("Judge output unparseable (attempt %d): %s", attempt + 1, raw[:200])

    logger.error("Judge failed to return parseable JSON twice; scoring 0")
    return 0.0